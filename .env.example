# Copy to .env and fill in. .env is gitignored.

# Spike 1 — Reddit (free; create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=srota-spike/0.1 by u/yourname

# Spike 2 — Agent
# Either OpenAI:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
# Or any OpenAI-compatible endpoint (Ollama, OpenRouter, Together, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
